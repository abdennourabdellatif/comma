# Auto normalize line endings for all text files
* text=auto

# Declare files that will always have LF line endings on checkout
*.json eol=lf
*.js eol=lf
*.jsx eol=lf
*.ts eol=lf
*.tsx eol=lf
*.md eol=lf
*.yml eol=lf
*.yaml eol=lf

# Windows scripts will use CRLF
*.bat eol=crlf
*.cmd eol=crlf
*.ps1 eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.otf binary
*.db binary
